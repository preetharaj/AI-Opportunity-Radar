# ============================================================
# AI Opportunity Radar — .gitignore
# ============================================================

# ── Environment variables ────────────────────────────────────
.env
.env.local
.env.production

# ── Astro build output ───────────────────────────────────────
dist/
.astro/

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Temp files ───────────────────────────────────────────────
*.tmp
*.temp
.cache/
