# ============================================================
# AI Opportunity Radar — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real values.

# ── Umami Analytics ──────────────────────────────────────────
# Get these from your Umami dashboard after setup.
# Leave blank to run in dev/console-only mode.

# Your Umami website ID (from Settings → Websites in Umami dashboard)
PUBLIC_UMAMI_WEBSITE_ID==

# Script URL — use default for Umami Cloud, or your self-hosted URL
# Default: https://cloud.umami.is/script.js
PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# ── Site URL ─────────────────────────────────────────────────
# Your production URL — used by RSS feed and sitemap
SITE=https://YOUR_USERNAME.github.io
