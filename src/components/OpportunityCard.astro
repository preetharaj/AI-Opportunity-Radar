---
/**
 * OpportunityCard.astro
 * Reusable card component for opportunity listings.
 */

interface Props {
  slug: string;
  category: string;
  title: string;
  provider: string;
  deadline: string;
  amount: string;
  region: string;
  summary: string;
  status: 'active' | 'closing-soon' | 'archived';
  tags: string[];
  best_for?: string[];
  effort_level?: 'low' | 'medium' | 'high';
  newThisWeek?: boolean;
  sampleData?: boolean;
}

const { slug, category, title, provider, deadline, amount, region, summary,
        status, tags, best_for, effort_level, newThisWeek, sampleData } = Astro.props;

const deadlineDate = new Date(deadline);
const formattedDeadline = deadlineDate.toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric'
});

const today = new Date();
const daysLeft = Math.ceil((deadlineDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));

// 3. Deadline urgency classes
const deadlineClass = status !== 'archived' && daysLeft > 0
  ? daysLeft <= 7 ? 'deadline-red'
  : daysLeft <= 30 ? 'deadline-orange'
  : 'deadline-green'
  : '';

const deadlineIcon = daysLeft <= 7 && status !== 'archived' ? '⚠ ' : '📅 ';

const daysLeftSuffix = (status !== 'archived' && daysLeft > 0 && daysLeft <= 60)
  ? ' (' + daysLeft + 'd left)' : '';

const statusLabel = { active: 'Active', 'closing-soon': 'Closing Soon', archived: 'Archived' }[status];
const statusClass = { active: 'badge-active', 'closing-soon': 'badge-closing', archived: 'badge-archived' }[status];

const categoryIcons: Record<string, string> = {
  grants: '💰', fellowships: '🎓', 'startup-programs': '🚀', competitions: '🏆', courses: '📚'
};
const icon = categoryIcons[category] ?? '⬡';

const effortEmoji: Record<string, string> = { low: '🟢', medium: '🟡', high: '🔴' };
const bestForLabel: Record<string, string> = {
  students: 'Students', researchers: 'Researchers', founders: 'Founders',
  phd: 'PhD holders', anyone: 'Anyone'
};

// 6. Share URL
const shareUrl = import.meta.env.SITE + import.meta.env.BASE_URL + `/opportunities/${category}/${slug}/`;
---

<article
  class:list={['opp-card', status === 'closing-soon' && 'closing', status === 'archived' && 'archived', sampleData && 'sample-card']}
  data-category={category}
  data-status={status}
>
  <header class="opp-card-header">
    <div style="flex:1; min-width:0;">
      {sampleData && <span class="badge badge-sample" style="margin-bottom:0.4rem;display:block;">⚠ Sample</span>}
      <!-- 2. New this week badge -->
      {newThisWeek && <span class="badge-new">✦ New</span>}
      <h3 class="opp-card-title">
        <a
          href={import.meta.env.BASE_URL + `/opportunities/${category}/${slug}/`}
          onclick={`trackEvent('opportunity-detail-view', { slug: '${slug}', category: '${category}' })`}
        >
          {icon} {title}
        </a>
      </h3>
    </div>
    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:0.35rem; flex-shrink:0;">
      <span class:list={['badge', statusClass]} aria-label={`Status: ${statusLabel}`}>
        {status === 'closing-soon' && '⚡ '}
        {statusLabel}
      </span>
      <!-- 6. Share button -->
      <button
        class="share-btn"
        title="Copy link"
        onclick={`navigator.clipboard.writeText('${shareUrl}').then(()=>{ this.textContent='✓ Copied'; setTimeout(()=>{ this.textContent='⎘ Copy link'; },1500); })`}
        aria-label="Copy opportunity link"
      >⎘ Copy link</button>
    </div>
  </header>

  <!-- 3. Deadline urgency color -->
  <div class="opp-card-meta" role="list">
    <span class="meta-item" role="listitem" aria-label="Provider">🏛 {provider}</span>
    <span class:list={['meta-item', 'deadline-meta', deadlineClass]} role="listitem" aria-label="Deadline">
      {deadlineIcon}{formattedDeadline}{daysLeftSuffix}
    </span>
    <span class="meta-item" role="listitem" aria-label="Value">💵 {amount}</span>
    <span class="meta-item" role="listitem" aria-label="Region">🌍 {region}</span>
  </div>

  {(best_for?.length || effort_level) && (
    <div class="opp-card-signals">
      {best_for && best_for.length > 0 && (
        <span class="signal-item">👤 {best_for.map(b => bestForLabel[b] ?? b).join(', ')}</span>
      )}
      {effort_level && (
        <span class="signal-item">
          {effortEmoji[effort_level]} Effort: {effort_level.charAt(0).toUpperCase() + effort_level.slice(1)}
        </span>
      )}
    </div>
  )}

  <p class="opp-card-summary">{summary}</p>

  <footer class="opp-card-footer">
    <div class="opp-card-tags" aria-label="Tags">
      {tags.slice(0, 4).map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    {status !== 'archived' && (
      <a
        href={import.meta.env.BASE_URL + `/opportunities/${category}/${slug}/`}
        class="btn btn-ghost"
        onclick={`trackEvent('opportunity-detail-view', { slug: '${slug}' })`}
      >
        View →
      </a>
    )}
  </footer>
</article>

<style>
.badge-new {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #fff;
  background: #16a34a;
  padding: 0.1rem 0.45rem;
  border-radius: 4px;
  margin-bottom: 0.3rem;
}
/* 3. Deadline urgency */
.deadline-red {
  color: #dc2626;
  font-weight: 600;
}
.deadline-orange {
  color: #ea580c;
  font-weight: 500;
}
.deadline-green {
  color: #16a34a;
}
/* 6. Share button */
.share-btn {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  padding: 0.15rem 0.4rem;
  border-radius: 4px;
  border: 1px solid var(--line);
  background: transparent;
  color: var(--muted);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.share-btn:hover {
  border-color: var(--blue);
  color: var(--blue);
}
.opp-card-signals {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin: 0.4rem 0 0.6rem;
}
.signal-item {
  font-size: 0.78rem;
  color: var(--muted);
  font-family: var(--font-mono);
}
</style>
