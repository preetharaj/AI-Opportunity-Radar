---
import BaseLayout from '../layouts/BaseLayout.astro';
import OpportunityCard from '../components/OpportunityCard.astro';
import { sortOpportunities } from '../utils/content';

const oppModules     = import.meta.glob('/content/opportunities/**/*.md', { eager: true }) as Record<string, any>;
const archiveModules = import.meta.glob('/content/archives/*.md', { eager: true }) as Record<string, any>;
const digestModules  = import.meta.glob('/content/weekly-digests/*.md', { eager: true }) as Record<string, any>;

const allOpportunities = Object.entries(oppModules).map(([filepath, mod]) => {
  const parts = filepath.split('/');
  const slug = parts.pop()!.replace('.md', '');
  const category = parts.pop()!;
  return { slug, category, ...mod.frontmatter };
});

const digests = Object.entries(digestModules)
  .map(([filepath, mod]) => ({ slug: filepath.split('/').pop()!.replace('.md', ''), ...mod.frontmatter }))
  .sort((a: any, b: any) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());

const activeOpps  = sortOpportunities(allOpportunities.filter((o: any) => o.status === 'active'));
const closingSoon = sortOpportunities(allOpportunities.filter((o: any) => o.status === 'closing-soon'));
const totalActive = activeOpps.length + closingSoon.length;
const categoryNames = [...new Set(allOpportunities.map((o: any) => o.category))];
const categories = categoryNames.length;

const featured = allOpportunities.find((o: any) => o.slug?.includes('thinking-machines-interactivity'))
  ?? activeOpps.find((o: any) => o.category === 'grants')
  ?? activeOpps[0]
  ?? closingSoon[0];

const latest = sortOpportunities([...activeOpps, ...closingSoon]).filter((o: any) => o.slug !== featured?.slug).slice(0, 3);
const allLive = sortOpportunities([...closingSoon, ...activeOpps]);

const countsByCategory = allOpportunities.reduce((acc: Record<string, number>, o: any) => {
  acc[o.category] = (acc[o.category] ?? 0) + 1;
  return acc;
}, {});

function regionTag(region: string): string {
  if (!region) return 'global';
  const r = region.toLowerCase();
  if (r.includes('india')) return 'india';
  if (r.includes('southeast asia') || r.includes('sea') || r.includes('singapore') || r.includes('indonesia') || r.includes('vietnam') || r.includes('philippines') || r.includes('malaysia') || r.includes('thailand')) return 'sea';
  if (r.includes('europe') || r.includes('eu ') || r.includes('uk') || r.includes('london') || r.includes('paris') || r.includes('berlin')) return 'europe';
  if (r.includes('usa') || r.includes('united states') || r.includes('washington') || r.includes('berkeley') || r.includes('americas')) return 'usa';
  if (r.includes('australia') || r.includes('csiro') || r.includes('australian')) return 'australia';
  return 'global';
}

const categoryLabel: Record<string, string> = {
  grants: 'Research Grants',
  fellowships: 'Fellowships',
  competitions: 'Competitions',
  courses: 'Courses',
  'startup-programs': 'Accelerators',
};

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title="AI Opportunity Radar" pageType="homepage">
  <section class="premium-home">
    <div class="site-shell premium-grid">
      <div class="main-column">
        <section class="hero-premium" aria-labelledby="hero-heading">
          <div class="hero-copy">
            <h1 id="hero-heading">Discover funding, fellowships<br/>and opportunities in AI.</h1>
            <p>Curated for founders, researchers and builders.<br/>Updated weekly.</p>
            <div class="hero-actions">
              <a href="#latest" class="btn btn-primary">Get New Opportunities</a>
              <a href={import.meta.env.BASE_URL + "/categories/"} class="btn btn-outline">Browse All Opportunities</a>
            </div>
          </div>

          <svg class="radar-large" viewBox="0 0 420 420" fill="none" aria-hidden="true">
            <circle cx="210" cy="210" r="170" stroke="currentColor" stroke-width="1" opacity=".13" />
            <circle cx="210" cy="210" r="120" stroke="currentColor" stroke-width="1" opacity=".13" />
            <circle cx="210" cy="210" r="74" stroke="currentColor" stroke-width="1" opacity=".13" />
            <circle cx="210" cy="210" r="32" stroke="currentColor" stroke-width="1" opacity=".08" />
            <path d="M210 210 L285 135 A106 106 0 0 1 313 238 Z" fill="url(#sweep)" opacity=".9" />
            <circle cx="300" cy="120" r="7" fill="#2454c6" />
            <circle cx="300" cy="120" r="15" fill="#2454c6" opacity=".12" />
            <defs><linearGradient id="sweep" x1="210" y1="210" x2="320" y2="120"><stop stop-color="#2454c6" stop-opacity=".45"/><stop offset="1" stop-color="#2454c6" stop-opacity=".04"/></linearGradient></defs>
          </svg>
        </section>

        {featured && (
          <section class="featured-block" aria-labelledby="featured-heading">
            <p class="section-label" id="featured-heading">Featured Opportunity</p>
            <article class="featured-card">
              <div class="featured-content">
                <span class="soft-pill">{categoryLabel[featured.category] ?? featured.category}</span>
                <h2>{featured.title}</h2>
                <p>{featured.summary}</p>
                <div class="featured-meta">
                  <span><b>$</b><small>Funding</small>{featured.amount}</span>
                  <span><b>▣</b><small>Deadline</small>{formatDate(featured.deadline)}</span>
                  <span><b>⌂</b><small>Organization</small>{featured.provider}</span>
                </div>
              </div>
              <div class="featured-logo">AI</div>
              <a class="featured-link" href={import.meta.env.BASE_URL + `/opportunities/${featured.category}/${featured.slug}/`}>View Opportunity →</a>
            </article>
          </section>
        )}

        <section id="latest" class="latest-block" aria-labelledby="latest-heading">
          <p class="section-label" id="latest-heading">Latest Opportunities</p>
          <div class="latest-list">
            {latest.map((opp: any) => (
              <a class="latest-row" href={import.meta.env.BASE_URL + `/opportunities/${opp.category}/${opp.slug}/`}>
                <span class="latest-icon">{opp.provider?.[0] ?? 'A'}</span>
                <span class="soft-pill">{categoryLabel[opp.category] ?? opp.category}</span>
                <strong>{opp.title}</strong>
                <span>{opp.amount}</span>
                <span>{formatDate(opp.deadline)}</span>
                <span class="row-arrow">→</span>
              </a>
            ))}
            <a class="view-all-link" href={import.meta.env.BASE_URL + "/categories/"}>View all opportunities →</a>
          </div>
        </section>

        <!-- ALL OPPORTUNITIES + REGION FILTER -->
        <section id="all-opps" class="all-opps-block" aria-labelledby="all-opps-heading">
          <div class="all-opps-header">
            <p class="section-label" id="all-opps-heading">All Active Opportunities</p>
            <div class="region-filter-inline" role="group" aria-label="Filter by region">
              <span class="filter-title">Filter by Region</span>
              <button class="chip chip-active" data-region="all" onclick="filterRegion('all')">🌐 All Regions</button>
              <button class="chip" data-region="global" onclick="filterRegion('global')">🌍 Global</button>
              <button class="chip" data-region="india" onclick="filterRegion('india')">🇮🇳 India</button>
              <button class="chip" data-region="sea" onclick="filterRegion('sea')">🌏 SEA</button>
              <button class="chip" data-region="europe" onclick="filterRegion('europe')">🇪🇺 Europe</button>
              <button class="chip" data-region="usa" onclick="filterRegion('usa')">🇺🇸 USA</button>
              <button class="chip" data-region="australia" onclick="filterRegion('australia')">🇦🇺 Australia</button>
              <span class="filter-count" id="filter-count" aria-live="polite"></span>
            </div>
          </div>
          <div class="opp-grid" id="home-opp-grid" role="list">
            {allLive.map((opp: any) => (
              <div role="listitem" data-region={regionTag(opp.region)}>
                <OpportunityCard {...opp} />
              </div>
            ))}
          </div>
          <div id="no-results" class="empty-state" style="display:none;">
            <p>No opportunities found for this region yet — check back next week.</p>
          </div>
        </section>
      </div>

      <aside class="right-rail" aria-label="Homepage sidebar">
        <section class="sidebar-card subscribe-card" id="subscribe">
          <div class="mail-icon">✉</div>
          <h2>Get new opportunities<br/>every week.</h2>
          <p>No spam. Just carefully curated AI grants, fellowships and programs delivered to your inbox.</p>
          <form onsubmit="event.preventDefault(); trackEvent('newsletter-signup-click'); alert('Newsletter signup coming soon');">
            <input type="email" placeholder="Enter your email" aria-label="Email address" required />
            <button type="submit" class="btn btn-primary">Subscribe</button>
          </form>
          <small>Join 3,200+ AI builders and researchers</small>
        </section>

        <section class="sidebar-card">
          <h3>Popular Categories</h3>
          <ul class="category-list">
            {Object.entries(categoryLabel).map(([slug, label]) => (
              <li><a href={import.meta.env.BASE_URL + `/categories/${slug}/`}><span>{label}</span><b>{countsByCategory[slug] ?? 0}</b></a></li>
            ))}
          </ul>
        </section>

        <section class="sidebar-card about-card">
          <h3>About AI Opportunity Radar</h3>
          <p>We curate high-quality AI opportunities from top organizations worldwide so you can focus on building and researching.</p>
          <a href={import.meta.env.BASE_URL + "/archive/"}>Learn more about our mission →</a>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
.all-opps-block {
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}
.all-opps-header {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.region-filter-inline {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  padding: 0.75rem 1rem;
  background: var(--color-surface);
  border: 1.5px solid var(--color-accent);
  border-radius: 8px;
}
.filter-title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-accent);
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 0.25rem;
}
.chip {
  font-family: var(--font-mono);
  font-size: 0.82rem;
  padding: 0.4rem 1rem;
  border-radius: 999px;
  border: 1.5px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text-muted);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  font-weight: 500;
}
.chip:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
}
.chip-active {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 2px 8px rgba(36,84,198,0.25);
}
.filter-count {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--color-text-muted);
  background: var(--color-bg);
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  border: 1px solid var(--color-border);
  margin-left: auto;
}
[data-region].hidden {
  display: none;
}
</style>

<script>
  function filterRegion(region: string) {
    document.querySelectorAll('.chip').forEach(chip => {
      const el = chip as HTMLElement;
      el.classList.toggle('chip-active', el.dataset.region === region);
    });

    const cards = document.querySelectorAll('#home-opp-grid [data-region]') as NodeListOf<HTMLElement>;
    let visible = 0;
    cards.forEach(card => {
      const match = region === 'all' || card.dataset.region === region || card.dataset.region === 'global';
      card.classList.toggle('hidden', !match);
      if (match) visible++;
    });

    const countEl = document.getElementById('filter-count');
    if (countEl) countEl.textContent = region === 'all' ? '' : `${visible} shown`;

    const noResults = document.getElementById('no-results');
    const grid = document.getElementById('home-opp-grid');
    if (noResults && grid) {
      noResults.style.display = visible === 0 ? 'block' : 'none';
      grid.style.display = visible === 0 ? 'none' : '';
    }
  }

  (window as any).filterRegion = filterRegion;
</script>
