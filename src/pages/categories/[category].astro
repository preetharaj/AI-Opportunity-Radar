---
/**
 * /categories/[category].astro
 * Generates one page per category (grants, fellowships, etc.)
 * Includes client-side region filter.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import OpportunityCard from '../../components/OpportunityCard.astro';
import { CATEGORIES, sortOpportunities } from '../../utils/content';

// import.meta.glob must be at module level (not inside getStaticPaths)
const oppModules = import.meta.glob('/content/opportunities/**/*.md', { eager: true }) as Record<string, any>;

function parseOppModules(modules: Record<string, any>) {
  return Object.entries(modules).map(([filepath, mod]) => {
    const parts = filepath.split('/');
    const slug = parts.pop()!.replace('.md', '');
    const category = parts.pop()!;
    return { slug, category, ...mod.frontmatter };
  });
}

export async function getStaticPaths() {
  const oppModulesInner = import.meta.glob('/content/opportunities/**/*.md', { eager: true }) as Record<string, any>;
  const allOpps = Object.entries(oppModulesInner).map(([filepath, mod]) => {
    const parts = filepath.split('/');
    const slug = parts.pop()!.replace('.md', '');
    const category = parts.pop()!;
    return { slug, category, ...mod.frontmatter };
  });

  const byCategory: Record<string, any[]> = {};
  for (const opp of allOpps) {
    if (!byCategory[opp.category]) byCategory[opp.category] = [];
    byCategory[opp.category].push(opp);
  }

  return CATEGORIES.map(cat => ({
    params: { category: cat.slug },
    props: {
      categoryMeta: cat,
      opportunities: sortOpportunities(byCategory[cat.slug] ?? []),
    },
  }));
}

const { categoryMeta, opportunities } = Astro.props;
const { slug: categorySlug, label, icon, description } = categoryMeta;

const active   = opportunities.filter((o: any) => o.status === 'active');
const closing  = opportunities.filter((o: any) => o.status === 'closing-soon');
const archived = opportunities.filter((o: any) => o.status === 'archived');
const liveCount = active.length + closing.length;

// Derive canonical region tag from region string
function regionTag(region: string): string {
  if (!region) return 'global';
  const r = region.toLowerCase();
  if (r.includes('india')) return 'india';
  if (r.includes('southeast asia') || r.includes('sea') || r.includes('singapore') || r.includes('indonesia') || r.includes('vietnam') || r.includes('philippines') || r.includes('malaysia') || r.includes('thailand')) return 'sea';
  if (r.includes('europe') || r.includes('eu ') || r.includes('uk') || r.includes('london') || r.includes('paris') || r.includes('berlin')) return 'europe';
  if (r.includes('usa') || r.includes('united states') || r.includes('washington') || r.includes('berkeley') || r.includes('americas')) return 'usa';
  if (r.includes('australia') || r.includes('csiro') || r.includes('australian')) return 'australia';
  return 'global';
}
---

<BaseLayout
  title={`${icon} ${label}`}
  description={`${description} — actively curated AI opportunities.`}
  pageType="category"
>
  <section class="category-hero" aria-labelledby="cat-heading">
    <div class="container">
      <a href={import.meta.env.BASE_URL} class="back-link">← All Opportunities</a>
      <div class="category-icon" aria-hidden="true">{icon}</div>
      <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
        <div>
          <h1 id="cat-heading">{label}</h1>
          <p style="color:var(--muted); margin-top:0.5rem; font-size:1.05rem;">{description}</p>
        </div>
        <div style="text-align:right;">
          <div style="font-family:var(--font-display); font-size:2.5rem; font-weight:800; color:var(--blue); line-height:1;">{liveCount}</div>
          <div style="font-family:var(--font-mono); font-size:0.72rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--muted);">Active</div>
        </div>
      </div>
      <div style="margin-top:2rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
        {CATEGORIES.filter(c => c.slug !== categorySlug).map(c => (
          <a href={import.meta.env.BASE_URL + `/categories/${c.slug}/`} class="btn btn-ghost" style="font-size:0.75rem;">
            {c.icon} {c.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- REGION FILTER BAR -->
  <div class="region-filter-bar" id="region-filter" aria-label="Filter by region">
    <div class="container">
      <div class="filter-heading">
        <span class="filter-title">Filter by Region</span>
        <span class="filter-count" id="filter-count" aria-live="polite"></span>
      </div>
      <div class="filter-chips" role="group" aria-label="Region filters">
        <button class="chip chip-active" data-region="all" onclick="filterRegion('all')">🌐 All Regions</button>
        <button class="chip" data-region="global" onclick="filterRegion('global')">🌍 Global</button>
        <button class="chip" data-region="india" onclick="filterRegion('india')">🇮🇳 India</button>
        <button class="chip" data-region="sea" onclick="filterRegion('sea')">🌏 SEA</button>
        <button class="chip" data-region="europe" onclick="filterRegion('europe')">🇪🇺 Europe</button>
        <button class="chip" data-region="usa" onclick="filterRegion('usa')">🇺🇸 USA</button>
        <button class="chip" data-region="australia" onclick="filterRegion('australia')">🇦🇺 Australia</button>
      </div>
    </div>
  </div>

  {closing.length > 0 && (
    <section class="section" aria-labelledby="closing-heading">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">⚡ Act fast</p>
            <h2 id="closing-heading">Closing Soon</h2>
          </div>
        </div>
        <div class="opp-grid" role="list" id="grid-closing">
          {closing.map((opp: any) => (
            <div role="listitem" data-region={regionTag(opp.region)}>
              <OpportunityCard {...opp} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section" aria-labelledby="active-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">Open now</p>
          <h2 id="active-heading">Active {label}</h2>
        </div>
        <span style="font-family:var(--font-mono); font-size:0.8rem; color:var(--muted);">{active.length} available</span>
      </div>
      {active.length > 0 ? (
        <div class="opp-grid" role="list" id="grid-active">
          {active.map((opp: any) => (
            <div role="listitem" data-region={regionTag(opp.region)}>
              <OpportunityCard {...opp} />
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="icon">{icon}</div>
          <p>No active {label.toLowerCase()} right now — check back next week.</p>
          {archived.length > 0 && (
            <a href={import.meta.env.BASE_URL + `/archive/#${categorySlug}`} class="btn btn-ghost" style="margin-top:1rem;">
              View {archived.length} archived →
            </a>
          )}
        </div>
      )}
    </div>
  </section>

  {archived.length > 0 && (
    <section class="section" aria-labelledby="archived-heading" style="background:var(--surface);">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-eyebrow">Closed</p>
            <h2 id="archived-heading">Archived {label}</h2>
          </div>
          <a href={import.meta.env.BASE_URL + "/archive/"} class="btn btn-ghost">Full archive →</a>
        </div>
        <div class="archive-list" id={categorySlug}>
          {archived.map((opp: any) => (
            <div class="archive-entry">
              <span class="archive-date">
                {new Date(opp.deadline).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
              <div>
                <a href={import.meta.env.BASE_URL + `/opportunities/${opp.category}/${opp.slug}/`} class="archive-title">{opp.title}</a>
                <span class="badge badge-archived" style="margin-left:0.5rem;">Archived</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
.region-filter-bar {
  position: sticky;
  top: 0;
  z-index: 40;
  background: var(--bg);
  border-top: 3px solid var(--blue);
  border-bottom: 1px solid var(--line);
  padding: 1rem 0;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}
.region-filter-bar .container {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.filter-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.filter-title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--blue);
  font-weight: 600;
}
.filter-chips {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.chip {
  font-family: var(--font-mono);
  font-size: 0.82rem;
  padding: 0.4rem 1rem;
  border-radius: 999px;
  border: 1.5px solid var(--line);
  background: var(--surface);
  color: var(--muted);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  font-weight: 500;
}
.chip:hover {
  border-color: var(--blue);
  color: var(--blue);
  background: var(--surface);
}
.chip-active {
  background: var(--blue);
  border-color: var(--blue);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 2px 8px rgba(36,84,198,0.25);
}
.filter-count {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--muted);
  background: var(--surface);
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  border: 1px solid var(--line);
}
[data-region].hidden {
  display: none;
}
[data-region].hidden {
  display: none;
}
</style>

<script>
  function filterRegion(region: string) {
    // Update chip states
    document.querySelectorAll('.chip').forEach(chip => {
      const el = chip as HTMLElement;
      el.classList.toggle('chip-active', el.dataset.region === region);
    });

    // Show/hide cards
    const cards = document.querySelectorAll('[data-region]') as NodeListOf<HTMLElement>;
    let visible = 0;
    cards.forEach(card => {
      const match = region === 'all' || card.dataset.region === region || card.dataset.region === 'global';
      card.classList.toggle('hidden', !match);
      if (match) visible++;
    });

    // Update count
    const countEl = document.getElementById('filter-count');
    if (countEl) {
      countEl.textContent = region === 'all' ? '' : `${visible} shown`;
    }

    // Hide empty section headers gracefully
    ['grid-closing', 'grid-active'].forEach(gridId => {
      const grid = document.getElementById(gridId);
      if (!grid) return;
      const anyVisible = Array.from(grid.querySelectorAll('[data-region]')).some(
        el => !(el as HTMLElement).classList.contains('hidden')
      );
      const section = grid.closest('section');
      if (section) section.style.display = anyVisible ? '' : 'none';
    });
  }

  // Expose globally for onclick
  (window as any).filterRegion = filterRegion;
</script>
