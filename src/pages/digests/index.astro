---
/**
 * /digests/index.astro — all weekly digests index
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const digestModules = import.meta.glob('/content/weekly-digests/*.md', { eager: true }) as Record<string, any>;

const digests = Object.entries(digestModules)
  .map(([filepath, mod]) => ({
    slug: filepath.split('/').pop()!.replace('.md', ''),
    ...mod.frontmatter,
  }))
  .sort((a: any, b: any) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());
---

<BaseLayout title="Weekly Digests" description="All weekly AI opportunity digests" pageType="digest">
  <section class="category-hero">
    <div class="container">
      <a href={import.meta.env.BASE_URL} class="back-link">← Home</a>
      <div class="category-icon">📬</div>
      <h1>Weekly Digests</h1>
      <p style="color:var(--color-text-muted); margin-top:0.5rem;">Every week's curated opportunity list, in one place.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {digests.length === 0 ? (
        <div class="empty-state">
          <div class="icon">📬</div>
          <p>No digests published yet — check back next week.</p>
        </div>
      ) : (
        <div class="opp-grid-wide">
          {digests.map((d: any) => (
            <article class="digest-card">
              <p class="digest-meta">
                Week #{d.weekNumber} ·
                {new Date(d.publishDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                {d.sampleData && <span class="badge badge-sample" style="margin-left:0.5rem;">Sample</span>}
              </p>
              <h2 style="font-size:1.1rem;"><a href={import.meta.env.BASE_URL + `/digests/${d.slug}/`}>{d.title}</a></h2>
              <p style="font-size:0.88rem; color:var(--color-text-muted); margin-top:0.5rem;">{d.summary}</p>
              <a href={import.meta.env.BASE_URL + `/digests/${d.slug}/`} class="btn btn-ghost" style="margin-top:1rem;">Read digest →</a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
