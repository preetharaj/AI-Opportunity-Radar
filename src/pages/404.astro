---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Not Found">
  <div class="container" style="text-align:center; padding:6rem 1rem;">
    <div style="font-size:4rem; margin-bottom:1.5rem;">⬡</div>
    <h1 style="font-size:1.5rem;">Page Not Found</h1>
    <p style="color:var(--color-text-muted); margin-top:0.75rem;">That opportunity may have expired or moved.</p>
    <div style="margin-top:2rem; display:flex; gap:0.75rem; justify-content:center; flex-wrap:wrap;">
      <a href={import.meta.env.BASE_URL} class="btn btn-primary">← Home</a>
      <a href={import.meta.env.BASE_URL + "archive/"} class="btn btn-ghost">Archive</a>
    </div>
  </div>
</BaseLayout>
